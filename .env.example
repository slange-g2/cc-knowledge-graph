LITELLM_API_BASE=http://localhost:4000
LITELLM_API_KEY=sk-your-key-here

EXTRACTION_MODEL=claude-haiku-4-5-20251001
EMBEDDING_MODEL=text-embedding-3-small
# full = all user messages; brief = title + first message only
EXTRACTION_MODE=full

SIMILARITY_THRESHOLD=0.92
RECENCY_WEIGHT=0.5
CONNECTION_WEIGHT=0.5

PORT=3000
# Number of sessions to extract+embed in parallel (DB writes are always sequential)
PARALLEL_WORKERS=3
# Set to true to reset all watermarks and re-ingest all sessions from scratch
FORCE_REINGEST=false
