{
  "name": "cc-timeline",
  "version": "0.1.0",
  "description": "Knowledge graph generator from Claude Code + OpenCode chat history",
  "type": "commonjs",
  "scripts": {
    "ingest": "tsx src/ingestion/run.ts",
    "server": "tsx src/server/index.ts",
    "dev": "concurrently \"npm run server\" \"vite --config vite.config.ts\"",
    "build": "vite build --config vite.config.ts",
    "type-check": "tsc --noEmit && tsc --noEmit -p tsconfig.frontend.json"
  },
  "dependencies": {
    "d3": "^7.9.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "openai": "^4.47.1"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@types/express": "^4.17.21",
    "@types/node": "^22.20.1",
    "concurrently": "^8.2.2",
    "tsx": "^4.15.6",
    "typescript": "^5.4.5",
    "vite": "^5.3.1"
  }
}
